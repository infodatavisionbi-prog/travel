# Copiá este archivo como .env y completá los valores

# Base de datos (Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Seguridad — generá con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-de-64-caracteres

# Sesión
TOKEN_EXPIRE_HOURS=8

# Registro público (false = solo el admin puede crear usuarios desde Configuración)
REGISTRATION_OPEN=false

# Primer usuario admin (solo se crea si la DB está vacía)
ADMIN_EMAIL=tu@email.com
ADMIN_PASSWORD=cambia-esta-clave

# CORS — ponés tu dominio en producción, ej: https://tuapp.railway.app
ALLOWED_ORIGINS=*

# Transporte de email: smtp | api
# smtp: usa SMTP tradicional (ideal para Railway Pro+)
# api: usa proveedor API por HTTPS (evita bloqueo SMTP en Railway Hobby/Free)
EMAIL_TRANSPORT_MODE=smtp

# Proveedor API (actualmente soportado: resend)
EMAIL_API_PROVIDER=resend
RESEND_API_KEY=

# Opcional: fuerza remitente verificado en Resend (ej: noreply@tudominio.com)
# Si queda vacio, se usa from_name/from_email de la campana o cuenta.
RESEND_FROM=

# Timeout para envio por API (segundos)
EMAIL_API_TIMEOUT_SECONDS=20

# OpenAI — requerido para transcripción de audios de WhatsApp con Whisper
# Obtené tu clave en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
